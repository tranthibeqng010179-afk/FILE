-- === ESP ===
local espObjects = {}  -- Bảng lưu các đối tượng Drawing cho mỗi player

-- Tạo Drawing objects cho một player
local function createESPForPlayer(plr)
    if plr == player then return end
    if espObjects[plr] then return end

    local boxLines = {}
    for i = 1, 4 do
        local line = Drawing.new("Line")
        line.Thickness = 2
        line.Color = Color3.new(1, 1, 1)
        line.Transparency = 1
        line.Visible = false
        table.insert(boxLines, line)
    end

    local healthBar = Drawing.new("Line")
    healthBar.Thickness = 3
    healthBar.Color = Color3.new(0, 1, 0)
    healthBar.Transparency = 1
    healthBar.Visible = false

    local nameText = Drawing.new("Text")
    nameText.Size = 16
    nameText.Center = true
    nameText.Outline = true
    nameText.Color = Color3.new(1, 1, 1)
    nameText.Transparency = 1
    nameText.Visible = false

    espObjects[plr] = {
        Box = boxLines,
        Health = healthBar,
        Name = nameText
    }
end

-- Xóa ESP của một player
local function destroyESPForPlayer(plr)
    local objs = espObjects[plr]
    if objs then
        for _, line in ipairs(objs.Box) do
            line:Remove()
        end
        objs.Health:Remove()
        objs.Name:Remove()
        espObjects[plr] = nil
    end
end

-- Xóa toàn bộ ESP
function clearESP()
    for plr, _ in pairs(espObjects) do
        destroyESPForPlayer(plr)
    end
end

-- Cập nhật ESP mỗi frame
local function updateESP()
    if not config.espEnabled then
        -- Ẩn tất cả nếu ESP tắt
        for plr, objs in pairs(espObjects) do
            for _, line in ipairs(objs.Box) do
                line.Visible = false
            end
            objs.Health.Visible = false
            objs.Name.Visible = false
        end
        return
    end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player then
            if not espObjects[plr] then
                createESPForPlayer(plr)
            end

            local character = plr.Character
            local objs = espObjects[plr]
            if character and character:FindFirstChild("HumanoidRootPart") and character:FindFirstChildOfClass("Humanoid") then
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                local rootPart = character.HumanoidRootPart
                local head = character:FindFirstChild("Head") or rootPart

                -- Lấy vị trí 2D của chân và đầu
                local headPos, headVis = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 1, 0))  -- Đỉnh đầu
                local rootPos, rootVis = camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 2, 0)) -- Chân

                if headVis and rootVis then
                    local height = (headPos.Y - rootPos.Y)
                    local width = height * 0.6  -- Tỷ lệ box
                    local centerX = headPos.X
                    local topY = headPos.Y
                    local bottomY = rootPos.Y

                    -- Tính tọa độ box
                    local left = centerX - width/2
                    local right = centerX + width/2

                    -- Vẽ box (4 đường)
                    if config.espShowBox then
                        -- Đường trên
                        objs.Box[1].From = Vector2.new(left, topY)
                        objs.Box[1].To = Vector2.new(right, topY)
                        objs.Box[1].Visible = true
                        -- Đường phải
                        objs.Box[2].From = Vector2.new(right, topY)
                        objs.Box[2].To = Vector2.new(right, bottomY)
                        objs.Box[2].Visible = true
                        -- Đường dưới
                        objs.Box[3].From = Vector2.new(right, bottomY)
                        objs.Box[3].To = Vector2.new(left, bottomY)
                        objs.Box[3].Visible = true
                        -- Đường trái
                        objs.Box[4].From = Vector2.new(left, bottomY)
                        objs.Box[4].To = Vector2.new(left, topY)
                        objs.Box[4].Visible = true
                    else
                        for _, line in ipairs(objs.Box) do
                            line.Visible = false
                        end
                    end

                    -- Vẽ thanh máu
                    if config.espShowHealth then
                        local healthPercent = humanoid.Health / humanoid.MaxHealth
                        local healthBarLength = width * healthPercent
                        objs.Health.From = Vector2.new(left, topY - 5)
                        objs.Health.To = Vector2.new(left + healthBarLength, topY - 5)
                        objs.Health.Color = Color3.new(1 - healthPercent, healthPercent, 0)  -- Đỏ -> xanh
                        objs.Health.Visible = true
                    else
                        objs.Health.Visible = false
                    end

                    -- Vẽ tên
                    if config.espShowName then
                        objs.Name.Position = Vector2.new(centerX, topY - 20)
                        objs.Name.Text = plr.Name
                        objs.Name.Visible = true
                    else
                        objs.Name.Visible = false
                    end
                else
                    -- Ẩn nếu không nhìn thấy
                    for _, line in ipairs(objs.Box) do
                        line.Visible = false
                    end
                    objs.Health.Visible = false
                    objs.Name.Visible = false
                end
            else
                -- Ẩn nếu nhân vật không tồn tại
                for _, line in ipairs(objs.Box) do
                    line.Visible = false
                end
                objs.Health.Visible = false
                objs.Name.Visible = false
            end
        end
    end
end

-- Kết nối update ESP
RunService.RenderStepped:Connect(updateESP)

-- Xóa ESP khi player rời
Players.PlayerRemoving:Connect(function(plr)
    destroyESPForPlayer(plr)
end)

-- === AIM SILENT ===
-- Tìm mục tiêu tốt nhất dựa trên phương thức
local function getBestTarget()
    local closestTarget = nil
    local closestDistance = math.huge

    local mousePos = UserInputService:GetMouseLocation()

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player then
            local character = plr.Character
            if character and character:FindFirstChild("HumanoidRootPart") and character:FindFirstChildOfClass("Humanoid") then
                local targetPart
                if config.aimPart == "Head" then
                    targetPart = character:FindFirstChild("Head") or character.HumanoidRootPart
                else
                    targetPart = character.HumanoidRootPart
                end

                local targetPos = targetPart.Position
                local targetPos2D, onScreen = camera:WorldToViewportPoint(targetPos)

                if onScreen then
                    if config.aimMethod == "FOV" then
                        -- Tính khoảng cách góc từ tâm màn hình
                        local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
                        local targetVec = Vector2.new(targetPos2D.X, targetPos2D.Y)
                        local dist = (targetVec - screenCenter).Magnitude
                        if dist < config.fovSize and dist < closestDistance then
                            closestDistance = dist
                            closestTarget = targetPart
                        end
                    else -- Mouse
                        local targetVec = Vector2.new(targetPos2D.X, targetPos2D.Y)
                        local dist = (targetVec - mousePos).Magnitude
                        if dist < config.fovSize and dist < closestDistance then
                            closestDistance = dist
                            closestTarget = targetPart
                        end
                    end
                end
            end
        end
    end
    return closestTarget
end

-- Xoay camera về mục tiêu
local function aimAtTarget(targetPart)
    if not targetPart then return end
    local cameraPos = camera.CFrame.Position
    local direction = (targetPart.Position - cameraPos).Unit
    camera.CFrame = CFrame.lookAt(cameraPos, cameraPos + direction)
end

-- Vòng lặp aim (nếu bật)
RunService.RenderStepped:Connect(function()
    if config.aimEnabled then
        local target = getBestTarget()
        if target then
            aimAtTarget(target)
        end
    end
end)

