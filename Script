local function createDropdown(menuName, items, anchorButton)
    local dropdown = Instance.new("Frame")
    dropdown.Name = menuName .. "Dropdown"
    dropdown.Size = UDim2.new(0, 260, 0, 0)  -- Rộng hơn một chút
    dropdown.Position = UDim2.new(0, 0, 1, 4)
    dropdown.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    dropdown.BackgroundTransparency = 0.15
    dropdown.BorderSizePixel = 0
    dropdown.Visible = false
    dropdown.Parent = anchorButton

    local dropdownCorner = Instance.new("UICorner")
    dropdownCorner.CornerRadius = UDim.new(0, 10)
    dropdownCorner.Parent = dropdown

    local dropdownShadow = Instance.new("ImageLabel")
    dropdownShadow.Name = "Shadow"
    dropdownShadow.Size = UDim2.new(1, 10, 1, 10)
    dropdownShadow.Position = UDim2.new(0, -5, 0, -5)
    dropdownShadow.BackgroundTransparency = 1
    dropdownShadow.Image = "rbxassetid://1316045217"
    dropdownShadow.ImageColor3 = Color3.new(0, 0, 0)
    dropdownShadow.ImageTransparency = 0.65
    dropdownShadow.ScaleType = Enum.ScaleType.Slice
    dropdownShadow.SliceCenter = Rect.new(10, 10, 118, 118)
    dropdownShadow.Parent = dropdown

    local itemsContainer = Instance.new("Frame")
    itemsContainer.Name = "ItemsContainer"
    itemsContainer.Size = UDim2.new(1, -16, 1, -16)
    itemsContainer.Position = UDim2.new(0, 8, 0, 8)
    itemsContainer.BackgroundTransparency = 1
    itemsContainer.Parent = dropdown

    local itemListLayout = Instance.new("UIListLayout")
    itemListLayout.FillDirection = Enum.FillDirection.Vertical
    itemListLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
    itemListLayout.VerticalAlignment = Enum.VerticalAlignment.Top
    itemListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    itemListLayout.Padding = UDim.new(0, 4)
    itemListLayout.Parent = itemsContainer

    for _, itemData in ipairs(items) do
        if itemData.Name == "Separator" then
            local separator = Instance.new("Frame")
            separator.Size = UDim2.new(1, -16, 0, 1)
            separator.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
            separator.BackgroundTransparency = 0.5
            separator.BorderSizePixel = 0
            separator.Parent = itemsContainer
        else
            local itemButton = Instance.new("TextButton")
            itemButton.Name = itemData.Name
            itemButton.Size = UDim2.new(1, 0, 0, 28)
            itemButton.BackgroundTransparency = 1
            itemButton.Text = ""
            itemButton.AutoButtonColor = false
            itemButton.Parent = itemsContainer

            -- Label chính (tên mục)
            local itemName = Instance.new("TextLabel")
            itemName.Size = UDim2.new(0.6, -10, 1, 0)
            itemName.Position = UDim2.new(0, 25, 0, 0)  -- Chừa chỗ cho checkmark
            itemName.BackgroundTransparency = 1
            itemName.Text = itemData.Name
            itemName.TextColor3 = Color3.fromRGB(50, 50, 50)
            itemName.TextXAlignment = Enum.TextXAlignment.Left
            itemName.Font = Enum.Font.SourceSans
            itemName.TextSize = 16
            itemName.Parent = itemButton

            -- Shortcut nếu có
            if itemData.Shortcut then
                local shortcutLabel = Instance.new("TextLabel")
                shortcutLabel.Size = UDim2.new(0.4, -10, 1, 0)
                shortcutLabel.Position = UDim2.new(0.6, 0, 0, 0)
                shortcutLabel.BackgroundTransparency = 1
                shortcutLabel.Text = itemData.Shortcut
                shortcutLabel.TextColor3 = Color3.fromRGB(120, 120, 120)
                shortcutLabel.TextXAlignment = Enum.TextXAlignment.Right
                shortcutLabel.Font = Enum.Font.SourceSans
                shortcutLabel.TextSize = 15
                shortcutLabel.Parent = itemButton
            end

            -- Checkmark cho các mục có Checked hoặc thuộc RadioGroup
            local checkmark = Instance.new("TextLabel")
            checkmark.Size = UDim2.new(0, 20, 1, 0)
            checkmark.Position = UDim2.new(0, 5, 0, 0)
            checkmark.BackgroundTransparency = 1
            checkmark.Text = ""  -- Sẽ cập nhật sau
            checkmark.TextColor3 = Color3.fromRGB(0, 120, 215)
            checkmark.TextSize = 18
            checkmark.Font = Enum.Font.SourceSansBold
            checkmark.Parent = itemButton

            -- Lưu itemData vào button
            itemButton:SetAttribute("ItemData", itemData)
            itemButton:SetAttribute("MenuName", menuName)
            itemButton:SetAttribute("Checkmark", checkmark)

            -- Cập nhật checkmark ban đầu
            if itemData.Checked ~= nil then
                checkmark.Text = itemData.Checked and "✓" or ""
            elseif itemData.RadioGroup then
                -- Với radio, ta sẽ xử lý sau dựa vào config
                -- Tạm thời để trống, sẽ cập nhật khi gán sự kiện
            end

            -- Hiệu ứng hover
            itemButton.MouseEnter:Connect(function()
                tweenObject(itemButton, {BackgroundTransparency = 0.85}, 0.1, "Quad", "Out")
            end)
            itemButton.MouseLeave:Connect(function()
                tweenObject(itemButton, {BackgroundTransparency = 1}, 0.15, "Quad", "Out")
            end)

            -- Xử lý click (sẽ được gán sau khi tạo tất cả)
        end
    end

    local function updateDropdownHeight()
        local contentHeight = itemListLayout.AbsoluteContentSize.Y
        dropdown.Size = UDim2.new(0, 260, 0, contentHeight + 16)
    end
    itemListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateDropdownHeight)
    task.wait()
    updateDropdownHeight()

    return dropdown
end

