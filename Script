-- Auto Farm (giữ từ script trước)
function startAutoFarm()
    if config.autoFarmEnabled then
        print("Auto Farm đã chạy rồi!")
        return
    end
    config.autoFarmEnabled = true
    print("Bắt đầu Auto Farm")

    autoFarmConnection = RunService.Heartbeat:Connect(function()
        if not config.autoFarmEnabled then return end

        local character = player.Character
        if not character or not character:FindFirstChild("HumanoidRootPart") then
            return
        end

        local humanoidRootPart = character.HumanoidRootPart
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not humanoid then return end

        local target = workspace:FindFirstChild(config.autoFarmTarget)
        if not target then
            humanoid:MoveTo(humanoidRootPart.Position)
            return
        end

        local distance = (target.Position - humanoidRootPart.Position).Magnitude
        if distance < 5 then
            target:Destroy()
            print("Đã thu thập:", target.Name)
        else
            humanoid:MoveTo(target.Position)
        end
    end)
    updateFarmIndicator()
end

function stopAutoFarm()
    if config.autoFarmEnabled then
        config.autoFarmEnabled = false
        if autoFarmConnection then
            autoFarmConnection:Disconnect()
            autoFarmConnection = nil
        end
        local character = player.Character
        if character and character:FindFirstChildOfClass("Humanoid") then
            character.Humanoid:MoveTo(character.HumanoidRootPart.Position)
        end
        print("Dừng Auto Farm")
    end
    updateFarmIndicator()
end

