-- Hàm cập nhật checkmark cho radio group
local function updateRadioGroup(menuName, groupName, selectedValue)
    for _, menuButton in ipairs(menuButtons) do
        if menuButton.Name:match("^"..menuName.."Button") then
            local dropdown = menuButton:GetAttribute("Dropdown")
            if dropdown then
                local itemsContainer = dropdown:FindFirstChild("ItemsContainer")
                if itemsContainer then
                    for _, itemButton in ipairs(itemsContainer:GetChildren()) do
                        if itemButton:IsA("TextButton") then
                            local itemData = itemButton:GetAttribute("ItemData")
                            if itemData and itemData.RadioGroup == groupName then
                                local checkmark = itemButton:GetAttribute("Checkmark")
                                if checkmark then
                                    -- Nếu item này là giá trị được chọn
                                    if itemData.Name:find(selectedValue) then
                                        checkmark.Text = "✓"
                                    else
                                        checkmark.Text = ""
                                    end
                                end
                            end
                        end
                    end
                end
            end
            break
        end
    end
end

-- Hàm cập nhật checkmark cho item có Checked
local function updateCheckedItem(menuName, itemName, checked)
    for _, menuButton in ipairs(menuButtons) do
        if menuButton.Name:match("^"..menuName.."Button") then
            local dropdown = menuButton:GetAttribute("Dropdown")
            if dropdown then
                local itemsContainer = dropdown:FindFirstChild("ItemsContainer")
                if itemsContainer then
                    for _, itemButton in ipairs(itemsContainer:GetChildren()) do
                        if itemButton:IsA("TextButton") then
                            local itemData = itemButton:GetAttribute("ItemData")
                            if itemData and itemData.Name == itemName then
                                local checkmark = itemButton:GetAttribute("Checkmark")
                                if checkmark then
                                    checkmark.Text = checked and "✓" or ""
                                end
                                break
                            end
                        end
                    end
                end
            end
            break
        end
    end
end

-- Hàm cập nhật giá trị hiển thị (ví dụ FOV Size)
local function updateValueDisplay(menuName, itemName, value)
    for _, menuButton in ipairs(menuButtons) do
        if menuButton.Name:match("^"..menuName.."Button") then
            local dropdown = menuButton:GetAttribute("Dropdown")
            if dropdown then
                local itemsContainer = dropdown:FindFirstChild("ItemsContainer")
                if itemsContainer then
                    for _, itemButton in ipairs(itemsContainer:GetChildren()) do
                        if itemButton:IsA("TextButton") then
                            local itemData = itemButton:GetAttribute("ItemData")
                            if itemData and itemData.Name:find(itemName) then
                                -- Cập nhật text của itemName (phần trước dấu hai chấm)
                                local nameLabel = itemButton:FindFirstChildOfClass("TextLabel")
                                if nameLabel then
                                    nameLabel.Text = itemName .. ": " .. tostring(value)
                                end
                                break
                            end
                        end
                    end
                end
            end
            break
        end
    end
end

